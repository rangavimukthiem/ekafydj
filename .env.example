# EKAFY Environment Variables Template
# Copy to .env and fill in values

# ─── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-this-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-vps-ip,your-domain.com
DJANGO_SETTINGS_MODULE=config.settings.production

# ─── Database ──────────────────────────────────────────────────────────────────
DB_NAME=ekafydj_db
DB_USER=ekafydj_user
DB_PASSWORD=strong-db-password
DB_HOST=localhost
DB_PORT=5432

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2

# ─── Email ─────────────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@yourdomain.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=EKAFY <noreply@yourdomain.com>

# ─── EKAFY Platform ────────────────────────────────────────────────────────────
EKAFY_BASE_DIR=/srv/ekafydj
EKAFY_PROJECTS_DIR=/srv/ekafydj/projects
EKAFY_LOGS_DIR=/srv/ekafydj/logs
EKAFY_BACKUPS_DIR=/srv/ekafydj/backups
EKAFY_DEPLOYMENTS_DIR=/srv/ekafydj/deployments
EKAFY_SCRIPTS_DIR=/srv/ekafydj/dashboard/scripts

# ─── S3 / Backblaze (optional) ─────────────────────────────────────────────────
USE_S3_BACKUPS=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=

# ─── Slack Notifications (optional) ────────────────────────────────────────────
SLACK_WEBHOOK_URL=

# ─── Sentry (optional) ─────────────────────────────────────────────────────────
SENTRY_DSN=

# ─── Security ──────────────────────────────────────────────────────────────────
CSRF_TRUSTED_ORIGINS=https://your-domain.com
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
